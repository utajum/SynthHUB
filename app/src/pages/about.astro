---
import Base from '../layouts/Base.astro';
import AppUpdate from '../components/AppUpdate';
import index from '../data/devices.index.json';
const count = (index as unknown[]).length;
---

<Base
  title="About - SynthHub - Behringer synth control in the browser"
  description="How SynthHub works: WebUSB discovery + WebMIDI SysEx control for Behringer synthesizers, an alternative to the SynthTribe desktop editor. 71 models, no install, offline-capable."
  keywords="about SynthHub, Behringer SynthTribe alternative, WebMIDI SysEx, WebUSB synth, Music Tribe, MIDI manufacturer 00 20 32"
>
  <section class="panel" style="margin-top:1rem">
    <header><span>about // manifest</span></header>
    <div class="body stack">
      <pre class="tiny hot" style="line-height:1.3">{`
 ___          _   _    _  _      _    
/ __|_  _ _ _| |_| |_ | || |_  _| |__ 
\\__ \\ || | ' \\  _| ' \\| __ | || | '_ \\
|___/\\_, |_||_\\__|_||_|_||_|\\_,_|_.__/
     |__/   pwa  -  webusb + webmidi control
`}</pre>

      <p>
        <span class="hot">SynthHub</span> is an alternative, browser-native
        reimplementation of Behringer's SynthTribe editor. It manages Behringer
        synthesizers directly from a Progressive Web App using
        <span class="hot"> WebUSB</span> for discovery and
        <span class="hot"> WebMIDI</span> (SysEx) for control - no install, no
        drivers, runs fully offline once loaded.
      </p>

      <table class="mono-table">
        <tbody>
          <tr><td class="muted">Models supported</td><td class="hot">{count}</td></tr>
          <tr><td class="muted">USB vendor id</td><td>0x1397 (Behringer / Music Tribe)</td></tr>
          <tr><td class="muted">SysEx manufacturer</td><td>00 20 32</td></tr>
          <tr><td class="muted">Stack</td><td>Astro - SolidJS - Zustand</td></tr>
          <tr><td class="muted">Transport</td><td>WebUSB discovery - WebMIDI SysEx-over-USB-MIDI</td></tr>
          <tr><td class="muted">Firmware</td><td>Version info + server compare (read-only); flashing is out of scope</td></tr>
        </tbody>
      </table>

      <p class="tiny dim">
        Not affiliated with, endorsed by, or connected to Behringer or Music
        Tribe. All trademarks belong to their respective owners. Provided as-is
        for interoperability and educational purposes.
      </p>
    </div>
  </section>

  <section class="panel" style="margin-top:1rem">
    <header><span>desktop apps // official</span></header>
    <div class="body stack">
      <p class="tiny hot" style="margin:0">SynthTribe</p>
      <AppUpdate app="synthtribe" name="SynthTribe" client:visible />
      <hr style="border:none;border-top:1px solid var(--border);width:100%;margin:0.3rem 0" />
      <p class="tiny hot" style="margin:0">Control Tribe (Swing)</p>
      <AppUpdate app="controltribe" name="Control Tribe" client:visible />
      <hr style="border:none;border-top:1px solid var(--border);width:100%;margin:0.3rem 0" />
      <p class="tiny hot" style="margin:0">GuitarTribe</p>
      <AppUpdate app="guitartribe" name="GuitarTribe" client:visible />
      <hr style="border:none;border-top:1px solid var(--border);width:100%;margin:0.3rem 0" />
      <p class="tiny hot" style="margin:0">MusicTribe Jam</p>
      <AppUpdate app="musictribejam" name="MusicTribe Jam" client:visible />
      <p class="tiny dim">
        This PWA is an alternative browser client. The official Behringer /
        Music Tribe desktop apps (macOS / Windows) are linked above when
        available.
      </p>
    </div>
  </section>
</Base>
